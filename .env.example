# ─────────────────────────────────────────────
#  M-EasyTools AI+ — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Google OAuth 2.0 credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The full URL where your app is hosted (no trailing slash)
# Local:      http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000

# Session secret — MUST be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/measytools

# Port the server listens on
PORT=3000

# Groq AI API key (free at console.groq.com)
GROQ_API_KEY=

# Set to "production" when deploying live
NODE_ENV=development

# Seller panel secret key
SELLER_KEY=

# iPay88 payment gateway
# Get credentials from: https://merchant.ipay88.com.my
IPAY88_MERCHANT_CODE=
IPAY88_MERCHANT_KEY=
IPAY88_SANDBOX=true

# Resend transactional email (resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
